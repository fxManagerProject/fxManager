{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "globalEnv": ["NODE_ENV"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "client/dist/**"],
            "cache": true
        },
        "dev": {
            "dependsOn": ["^build"],
            "persistent": true,
            "cache": false
        },
        "dev:isolated": {
            "persistent": true,
            "cache": false
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "cache": true
        },
        "lint": {
            "cache": true,
            "outputs": []
        }
    }
}