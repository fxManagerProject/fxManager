# Panel web server port
PANEL_PORT=4000

# fxServer server executable path
FXSERVER_EXECUTABLE=./FXServer

# Path to your server-data folder
FXSERVER_DATA_PATH=./server-data

DEPLOY_PATH=./server-data/resources/[dev-resources]/fxManager

# Config file inside server-data
FXSERVER_CFG=server.cfg

# Auto-start the fxServer when the panel launches (once setup is complete).
# Default: on. The in-panel toggle (fxserver.autostart) overrides this.
FXSERVER_AUTOSTART=true

NODE_ENV=production
